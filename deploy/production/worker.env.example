WATCHLIST_SOURCE=watchlist_app
WATCHLIST_APP_URL=http://watchlist-api:8080
WATCHLIST_APP_SYNC_KEY=
WATCHLIST_APP_SYNC_FIRST=true
WATCHLIST_APP_TIMEOUT_SECONDS=30
WATCHLIST_APP_SYNC_TIMEOUT_SECONDS=900

MOVIE_SYNC_APPLY=false
MOVIE_SYNC_MAX_SOURCE_AGE_MINUTES=120
MOVIE_SYNC_MAX_REMOVAL_COUNT=10
MOVIE_SYNC_MAX_REMOVAL_PERCENT=25
MOVIE_SYNC_ALLOW_WATCHED_FILE_DELETION=false

RADARR_URL=
RADARR_API_KEY=
RADARR_QUALITY_PROFILE_ID=1
RADARR_ROOT_FOLDER=/movies

PLEX_URL=
PLEX_TOKEN=
PLEX_LIBRARY_NAME=Movies

SYNC_INTERVAL=3600
LOG_LEVEL=INFO
DATABASE_PATH=/app/data/vod-filter.db
WORKER_HEARTBEAT_PATH=/app/data/last-run.json
WORKER_HEALTH_MAX_AGE_SECONDS=7500

TRAKT_HISTORY_SYNC_APPLY=false
TV_SYNC_APPLY=false
TV_SYNC_ADOPT_EXISTING_DESTINATIONS=false
TV_SYNC_ALLOW_SEASON_FILE_DELETION=false
TV_SYNC_ALLOW_TERMINAL_SERIES_DELETION=false
TV_SYNC_ALLOW_NO_RECYCLE_BIN_DELETE=false
