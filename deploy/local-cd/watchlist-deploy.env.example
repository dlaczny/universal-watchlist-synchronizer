DEPLOY_ROOT=/opt/watchlist-prod
REPOSITORY_DIR=/opt/watchlist-prod/repository
CONFIG_DIR=/opt/watchlist-prod/config
DATA_DIR=/opt/watchlist-prod/data
STATE_DIR=/opt/watchlist-prod/state
