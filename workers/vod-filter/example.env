# Letterboxd Configuration
LETTERBOXD_USERNAME=your_username_here

# TMDB Configuration
TMDB_API_KEY=your_tmdb_api_key_here

# Radarr Configuration
RADARR_URL=http://localhost:7878
RADARR_API_KEY=your_radarr_api_key_here
RADARR_QUALITY_PROFILE_ID=1
RADARR_ROOT_FOLDER=/movies/

# Plex Configuration
PLEX_URL=http://localhost:32400
PLEX_TOKEN=your_plex_token_here

# VOD Provider Configuration
# Option 1: Simple format - Comma-separated list of TMDB provider IDs
# Common provider IDs:
#   119 = Amazon Prime Video
#   1899 = HBO Max
#   1773 = SkyShowtime
#   8   = Netflix
#   337 = Disney Plus
#   350 = Apple TV Plus
# Verify configured provider IDs with:
#   python validate_providers.py
VOD_PROVIDERS=119,1899,1773
VOD_REGION=PL

# Option 2: Advanced format (JSON) - Full control over provider configuration
# Use this format if you need to specify custom provider names or temporarily disable providers
# VOD_PROVIDERS_JSON=[{"provider_id": 119, "provider_name": "Prime Video", "enabled": true}, {"provider_id": 1899, "provider_name": "HBO Max", "enabled": true}, {"provider_id": 1773, "provider_name": "SkyShowtime", "enabled": true}]

# Note: VOD_PROVIDERS_JSON takes precedence over VOD_PROVIDERS if both are set
# The application will filter movies available on ANY of the enabled providers

# Sync Settings
# How often to sync in seconds (default: 3600 = 1 hour)
# SYNC_INTERVAL is the production Docker/continuous-loop interval.
# SYNC_INTERVAL_HOURS is a legacy one-shot compatibility field; omit it unless needed.
SYNC_INTERVAL=3600
# SYNC_INTERVAL_HOURS=1
DRY_RUN=false

# Watchlist Source
# letterboxd = Python fetches Letterboxd directly.
# watchlist_app = Python consumes watchlist-app API export and keeps destructive actions here.
WATCHLIST_SOURCE=letterboxd
# WATCHLIST_APP_URL=http://localhost:5000
# WATCHLIST_APP_SYNC_FIRST=false
# WATCHLIST_APP_TIMEOUT_SECONDS=30
# WATCHLIST_APP_SYNC_TIMEOUT_SECONDS=900

# Radarr Removal Settings
# When removing movies from Radarr (bidirectional sync), should downloaded files be deleted?
# This applies to movies removed from your Letterboxd watchlist.
RADARR_DELETE_FILES_ON_REMOVAL=true
# Required for non-dry-run cleanup when movies would be removed.
# Leave false for first runs; use --confirm-destructive-cleanup or set true after reviewing reports.
CONFIRM_DESTRUCTIVE_CLEANUP=false

# VOD Availability Monitoring
# Remove downloaded movies from Radarr when they become available on VOD services.
RADARR_REMOVE_WHEN_VOD_AVAILABLE=true
# Delete files for downloaded movies removed because they became available on VOD.
# Default is false so you can keep local files while still removing from Radarr.
RADARR_DELETE_FILES_WHEN_VOD_AVAILABLE=false

# Plex Rate Limit Settings
# Wait time in seconds when encountering 429 (rate limit) errors from Plex
PLEX_RATE_LIMIT_WAIT_SECONDS=60

# Cache Settings
# How long to cache VOD availability data (in hours)
CACHE_TTL_HOURS=48

# Plex Watchlist Caching
# Cache Plex watchlist for faster syncs (avoids API call every time)
# Set to number of minutes (0 to disable caching, recommended: 30)
PLEX_WATCHLIST_CACHE_MINUTES=30

# Logging Configuration (optional)
# Use WARNING for quieter dry-runs.
LOG_LEVEL=INFO
LOG_FILE=

# Database Configuration
DATABASE_PATH=./data/vod-filter.db
